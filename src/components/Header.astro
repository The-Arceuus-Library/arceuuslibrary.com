---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://x.com/ArceuusLibrary" target="_blank">
				<span class="sr-only">The Arceuus Library on X</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://github.com/The-Arceuus-Library/arceuuslibrary.com" target="_blank">
				<span class="sr-only">The Arceuus Library on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgb(var(--black));
		border-bottom: 1px solid rgba(var(--gray-light), 0.12);
		box-shadow: 0 2px 24px rgba(0, 0, 0, 0.6), 0 1px 0 var(--accent-dark);
		position: relative;
		z-index: 10;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		font-family: var(--font-display);
		font-size: 1.15em;
		font-weight: 600;
		letter-spacing: 0.06em;
		color: var(--accent);
		text-decoration: none;
		text-shadow: 0 0 18px var(--accent-glow);
		transition: color 200ms, text-shadow 200ms;
	}
	h2 a:hover {
		color: rgb(255, 220, 150);
		text-shadow: 0 0 24px var(--accent-glow);
	}
	nav {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
	}
	.social-links {
		justify-self: end;
	}
	nav a {
		padding: 1em 0.6em;
		font-family: var(--font-display);
		font-size: 0.8em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgb(var(--gray-light));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		transition: color 200ms, border-color 200ms, text-shadow 200ms;
	}
	nav a:hover {
		color: var(--accent);
		text-shadow: 0 0 10px var(--accent-glow);
		border-bottom-color: rgba(201, 169, 97, 0.4);
	}
	nav a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		gap: 0.25em;
	}
	.social-links a {
		color: rgb(var(--gray));
		padding: 1em 0.4em;
		border-bottom: none;
		transition: color 200ms;
	}
	.social-links a:hover {
		color: var(--accent);
		text-shadow: none;
		border-bottom-color: transparent;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
