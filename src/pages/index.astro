---
import BaseHead from '../components/BaseHead.astro';
import EmailCapture from '../components/EmailCapture.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{SITE_TITLE}</h1>
			<p>
				The library is under construction. We are cataloguing books of arcane knowledge on
				the markets, mechanics, and history of Old School RuneScape — guides, deep dives,
				and economic analysis, written for those who wish to understand the game beyond
				the surface.
			</p>
			<p>
				New volumes are added as they are completed. Leave your email address below to be notified.
			</p>
			<EmailCapture />
		</main>
		<Footer />
	</body>
</html>
